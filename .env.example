# Copy to `.env` for local runs. Do NOT commit `.env`.
#
# Values below target the default path: ``docker compose up -d`` from this repo (FastAPI, Postgres,
# LocalStack, SFTPGo on one Docker network). The API container uses ``SFTP_HOST=sftpgo`` and
# ``AWS_ENDPOINT_URL=http://localstack:4566`` â€” hostnames that only resolve inside Compose.
#
# If you run the app on the host (Poetry / IDE) while services run in Docker, override at least:
#   POSTGRES_HOST=localhost
#   AWS_ENDPOINT_URL=http://127.0.0.1:4566
#   SFTP_HOST=127.0.0.1
#   SFTP_PORT=2022
#
# Variable names match ``edc_ingestion.config.Settings`` and ``alembic/env.py`` only. Fargate sets
# ``ECS_CONTAINER_METADATA_URI`` at runtime; leave it unset here.


# -----------------------------------------------------------------------------
# Postgres (compose service ``postgres_db``; mapped to localhost:5432 on the host)
# -----------------------------------------------------------------------------
POSTGRES_USER=edc_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=edc_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# SQLAlchemy pool (``edc_ingestion.database``)
# -----------------------------------------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Alembic CLI default tenant when ``-x schema=`` is omitted
# -----------------------------------------------------------------------------
ALEMBIC_SCHEMA=sponsor_demo

# -----------------------------------------------------------------------------
# LocalStack (compose service ``localstack`` â€” in-container endpoint below)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# -----------------------------------------------------------------------------
# App runtime (compose service ``fastapi_trigger``)
# -----------------------------------------------------------------------------
EDC_ENVIRONMENT=local-compose
LOCAL_RUNTIME_MODE=compose
ONBOARD_SPONSORS=sponsor_demo
EDC_SPONSOR_SCHEMA=sponsor_demo

# -----------------------------------------------------------------------------
# S3 / SNS (bucket and topic names match ``docker-compose`` LocalStack bootstrap)
# -----------------------------------------------------------------------------
S3_RAW_BUCKET=edc-raw-layer
S3_DROP_BUCKET=edc-drop-site
# Raw-bucket landing zone (outputs): LocalStack sample CSV under ``{prefix}{studyId}/``; ingestion Parquet at ``{prefix}{studyId}/normalized/{runId}/{sourceStem}.parquet`` (one folder per run; filename from each SFTP CSV stem). Not the SFTP source tree.
S3_SFTP_LANDING_PREFIX=sftp-landing/
S3_PARTIAL_API_STASH_PREFIX=partial-api-pulls/
S3_PIPELINE_STAGING_PREFIX=pipeline-staging/
S3_PIPELINE_STATE_PREFIX=pipeline-state/
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:edc-pipeline-alerts

# -----------------------------------------------------------------------------
# Subject-visit API / OAuth2 (SVDS). Leave empty unless you call the real API.
# ``SFTP_ONLY`` matches local SFTPGo + filled ``SFTP_*`` below. ``API_ONLY`` = API visits only.
# ``API_FIRST`` = API visits, then SFTP subject_group / misc CSVs (not subjectvisit_*); if API fails, all SFTP CSVs.
# when ``EDC_SUBJECT_VISIT_API_BASE_URL`` and OAuth vars are set.
# -----------------------------------------------------------------------------
EDC_SUBJECT_VISIT_API_BASE_URL=
# Subject-visit list page size; staging APIs often cap this (e.g. 100â€“1000). Raise only if your API allows it.
EDC_SUBJECT_VISIT_PAGE_SIZE=500
EDC_SUBJECT_VISIT_SOURCE_MODE=SFTP_ONLY
EDC_PIPELINE_DEPTH=PUBLISH
EDC_OAUTH2_TOKEN_URL=
EDC_OAUTH2_CLIENT_ID=
EDC_OAUTH2_CLIENT_SECRET=
EDC_OAUTH2_TIMEOUT_SECONDS=120
EDC_API_TIMEOUT_SECONDS=300
EDC_CIRCUIT_FAILURE_THRESHOLD=5
EDC_CIRCUIT_RECOVERY_SECONDS=60

# -----------------------------------------------------------------------------
# SFTPGo (compose service ``sftpgo`` â€” WebAdmin :8080, SFTP :2022)
# https://awesome-docker-compose.com/sftpgo
#
# WebAdmin: http://localhost:8080/web/admin  â†’ SFTPGO_DEFAULT_ADMIN_*
# WebClient: http://localhost:8080/web/client â†’ SFTP user from ``docker/sftpgo/loaddata.json`` (edc/edc)
# -----------------------------------------------------------------------------
SFTPGO_DEFAULT_ADMIN_USERNAME=admin
SFTPGO_DEFAULT_ADMIN_PASSWORD=change_me

# -----------------------------------------------------------------------------
# SFTP **source** tree on SFTPGo (bootstrap + ``SFTPIngestor``): ``{prefix}/{studyId}/*.csv`` under user home.
# ``docker compose --profile bootstrap run --rm sftpgo_bootstrap`` copies ``input_files/by_study`` here.
# Separate from ``S3_SFTP_LANDING_PREFIX`` (S3 landing for ingestion outputs).
# -----------------------------------------------------------------------------
SFTPGO_LANDING_PREFIX=input-files/

# -----------------------------------------------------------------------------
# App â†’ SFTP (``SFTPIngestor`` / Paramiko). These point the API container at compose ``sftpgo``.
# Password auth; leave key fields empty unless you use key-based login.
# -----------------------------------------------------------------------------
SFTP_HOST=sftpgo
SFTP_PORT=2022
SFTP_USER=edc
SFTP_PASSWORD=edc
SFTP_PRIVATE_KEY_PATH=
SFTP_PRIVATE_KEY_PASSPHRASE=

# -----------------------------------------------------------------------------
# Logging (``edc_ingestion.logging_config`` / ``tasks.common.logging``)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=
DASK_LOGGING__DISTRIBUTED=WARNING
